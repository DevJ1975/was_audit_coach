# Soteria Audit — Expo public env (Phase 4+). Copy to .env and fill.
# Expo exposes only EXPO_PUBLIC_*-prefixed vars to the client bundle.
# The publishable key is the new public-format Supabase key — safe on the client;
# tenant isolation is enforced by Postgres RLS, never by the client.
EXPO_PUBLIC_SUPABASE_URL=https://tvgutsihvyjflqsihxxi.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx_replace_me

# Server-only (Edge Function secrets — NEVER prefixed EXPO_PUBLIC_, never in the app bundle):
#   ANTHROPIC_API_KEY=...            # ai-draft function (Phase 3)
#   SUPABASE_SERVICE_ROLE_KEY=...    # server-side only
