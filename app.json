{
  "expo": {
    "name": "WLS Audit Coach",
    "slug": "soteria-audit",
    "version": "0.2.0",
    "scheme": "soteria",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#131417",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#131417",
      "image": "./public/icons/icon-512.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trainovate.wlsauditcoach"
    },
    "android": {
      "package": "com.trainovate.wlsauditcoach",
      "adaptiveIcon": {
        "backgroundColor": "#131417",
        "foregroundImage": "./public/icons/icon-1024.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "name": "WLS Audit Coach",
      "shortName": "Audit Coach",
      "description": "Offline-first EHS audit platform",
      "themeColor": "#1E2023",
      "backgroundColor": "#131417",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "en",
      "favicon": "./public/icons/icon-48.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach photos as audit evidence.",
          "cameraPermission": "Capture photos as audit evidence."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Record voice notes as audit evidence."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "icon": "./public/icons/icon-1024.png"
  }
}
