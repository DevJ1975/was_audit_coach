{
  "name": "soteria-audit",
  "version": "0.2.0",
  "private": true,
  "description": "Soteria Audit (WLS Audit Coach) \u2014 offline-first EHS audit platform. Scoring parity is sacred.",
  "main": "expo-router/entry",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "etl": "tsx scripts/etl.ts",
    "gen:seed": "tsx scripts/gen_cloud_seed.ts",
    "reg-etl": "tsx scripts/reg-etl/run.ts",
    "build:web": "expo export --platform web && node scripts/postexport.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "fast-xml-parser": "^5.9.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@supabase/supabase-js": "^2.110.2",
    "@types/react": "~19.0.10",
    "expo": "^53.0.27",
    "expo-asset": "~11.1.7",
    "expo-av": "~15.1.7",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-file-system": "~18.1.11",
    "expo-image-picker": "~16.1.4",
    "expo-linking": "~7.1.7",
    "expo-print": "~14.1.4",
    "expo-router": "~5.1.11",
    "expo-sharing": "~13.1.5",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.11",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-paper": "^5.15.3",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.20.0"
  }
}
